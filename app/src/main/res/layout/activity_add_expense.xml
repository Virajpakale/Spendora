<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Heading -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How much did you spend?"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <!-- Amount -->
        <EditText
            android:id="@+id/etAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter amount"
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA"
            android:textSize="20sp"
            android:backgroundTint="#FFFFFF"
            android:inputType="numberDecimal"
            android:layout_marginTop="30dp" />

        <!-- Category title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose Category"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="10dp" />

        <!-- Category Grid -->
        <GridLayout
            android:id="@+id/categoryGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="4"
            android:layout_marginTop="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFood"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:text="🍔 Food"
                android:textColor="#FFFFFF"
                app:backgroundTint="#151515"
                app:cornerRadius="16dp"
                app:rippleColor="#33F59E0B"
                app:strokeColor="#66F59E0B"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTransport"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:text="🚕 Transport"
                android:textColor="#FFFFFF"
                app:backgroundTint="#151515"
                app:cornerRadius="16dp"
                app:rippleColor="#33F59E0B"
                app:strokeColor="#66F59E0B"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShopping"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:text="🛍 Shopping"
                android:textColor="#FFFFFF"
                app:backgroundTint="#151515"
                app:cornerRadius="16dp"
                app:rippleColor="#33F59E0B"
                app:strokeColor="#66F59E0B"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEntertainment"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:text="🎬 Entertainment"
                android:textColor="#FFFFFF"
                app:backgroundTint="#151515"
                app:cornerRadius="16dp"
                app:rippleColor="#33F59E0B"
                app:strokeColor="#66F59E0B"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBills"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:text="💡 Bills"
                android:textColor="#FFFFFF"
                app:backgroundTint="#151515"
                app:cornerRadius="16dp"
                app:rippleColor="#33F59E0B"
                app:strokeColor="#66F59E0B"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHealth"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:text="❤️ Health"
                android:textColor="#FFFFFF"
                app:backgroundTint="#151515"
                app:cornerRadius="16dp"
                app:rippleColor="#33F59E0B"
                app:strokeColor="#66F59E0B"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPersonal"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:text="👤 Personal"
                android:textColor="#FFFFFF"
                app:backgroundTint="#151515"
                app:cornerRadius="16dp"
                app:rippleColor="#33F59E0B"
                app:strokeColor="#66F59E0B"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOther"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:text="📦 Other"
                android:textColor="#FFFFFF"
                app:backgroundTint="#151515"
                app:cornerRadius="16dp"
                app:rippleColor="#33F59E0B"
                app:strokeColor="#66F59E0B"
                app:strokeWidth="2dp" />

        </GridLayout>

        <!-- Note -->
        <EditText
            android:id="@+id/etNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Add note"
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA"
            android:backgroundTint="#FFFFFF"
            android:layout_marginTop="30dp" />

        <!-- Save button -->
        <Button
            android:id="@+id/btnSaveExpense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Expense"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#F59E0B"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="20dp" />

    </LinearLayout>

</ScrollView>